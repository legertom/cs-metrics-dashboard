# ─────────────────────────────────────────────────────────────────────────────
# CS Metrics Dashboard — environment configuration
# ─────────────────────────────────────────────────────────────────────────────
#
# SETUP INSTRUCTIONS
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Fill in your Talkdesk credentials below (see README.md for where to find them).
# 3. Set USE_MOCK_DATA=false when you're ready to pull live data.
#
# .env.local is listed in .gitignore — your credentials will never be committed.
# ─────────────────────────────────────────────────────────────────────────────


# Your Talkdesk account subdomain.
# This is the part before ".talkdesk.com" when you log in.
# e.g. if your login URL is https://acme.talkdesk.com  →  TALKDESK_ACCOUNT=acme
TALKDESK_ACCOUNT=youraccountname

# OAuth 2.0 client credentials.
# Create these in Talkdesk Admin → Integrations → API Clients → New Client.
# Grant the scopes: contacts:read, wfm:read, qm:read  (add only what your plan includes).
TALKDESK_CLIENT_ID=your_client_id
TALKDESK_CLIENT_SECRET=your_client_secret

# Set to true to use built-in sample data (no API calls made).
# Set to false once your credentials above are filled in.
USE_MOCK_DATA=true
